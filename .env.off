# Copy this file to ".env" and put a long random string below.
# The real .env is NOT committed to GitHub (it's in .gitignore).

# App secret — put any long random string here.
SECRET_KEY = 'sk-9f3kd02ja8sleo29xkqp1mzv7'

# ---- Shared MySQL on Aiven (optional) ----
# Leave BOTH of these commented out to keep using the local SQLite file.
# Uncomment and fill in to use the shared team database instead.
#
# From the Aiven service page, copy the "Service URI" and rewrite it as:
#   mysql+pymysql://USER:PASSWORD@HOST:PORT/DBNAME
# (change the leading "mysql://" to "mysql+pymysql://")
#
DATABASE_URL=mysql+pymysql://avnadmin:(email)@mysql-870fc8c-sparkle-a984.l.aivencloud.com:21017/defaultdb
#
# Path to Aiven's CA certificate (download "CA Certificate" from the Aiven
# console). Defaults to certs/aiven-ca.pem, so if you save it there you can
# leave this commented out.
MYSQL_SSL_CA=certs/aiven-ca.pem